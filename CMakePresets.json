{
  "version": 4,
  "vendor": {
    "falcon-autotuning/falcon-deps": {}
  },
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (x64-linux-dynamic)",
      "description": "Default build using Ninja and vcpkg x64-linux-dynamic triplet with NuGet caching support",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "VCPKG_FEATURE_FLAGS": "binarycaching"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "jobs": 4
    }
  ]
}
