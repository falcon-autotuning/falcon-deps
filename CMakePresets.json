{
  "version": 4,
  "vendor": {
    "falcon-autotuning/falcon-deps": {}
  },
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (x64-linux-dynamic)",
      "description": "Default build using Ninja, vcpkg x64-linux-dynamic triplet with NuGet caching",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "VCPKG_FEATURE_FLAGS": "binarycaching"
      },
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "ci",
      "displayName": "CI (x64-linux-dynamic with NuGet)",
      "description": "CI build for x64-linux-dynamic triplet with NuGet binary caching and readwrite access",
      "inherits": "default",
      "cacheVariables": {
        "VCPKG_BINARY_SOURCES": "clear;nuget,${env:NUGET_FEED_URL},readwrite"
      },
      "environment": {
        "NUGET_FEED_URL": "${env:NUGET_FEED_URL}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "jobs": 4
    },
    {
      "name": "ci",
      "configurePreset": "ci",
      "jobs": 4
    }
  ]
}
